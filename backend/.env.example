# Copy this file to .env and fill in your values.
# No external API key is required -- the chatbot logic runs entirely on this
# server (see backend/bot.js). These settings just control cookies and flags.

# A random long string used to sign session cookies. Change this to your own random value.
SESSION_SECRET=change-me-to-a-long-random-string

# Port the backend listens on
PORT=3001

# Seed used to derive this deployment's unique flags. Change it and every flag changes.
FLAG_SEED=change-me-too
